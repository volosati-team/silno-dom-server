# Скопировать в .env и заполнить (не коммитить .env!)
WEB_PORT=8080
HOME_HOST=localhost
HOME_PORT=1883
MOIO_MAC=782184803ce4

# Multi-user web auth
PASS_VOLOSATI=12345
PASS_MAX=12345
PASS_GUEST=

# MQTT broker auth (должно совпадать с mqtt_passwords файлом)
# Если не задано — start.sh использует дефолты: silnodom/12345
MQTT_USER=silnodom
MQTT_PASS=12345

# CF KV auto-update (опционально — чтобы workers подхватывали новый URL тоннеля автоматически)
# CF_API_TOKEN=your_token_here
# CF_ACCOUNT_ID=c3c77a3221c555b27c46225899a0143d
